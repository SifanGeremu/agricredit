# MongoDB (Atlas or local)
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/agricredit?retryWrites=true&w=majority"

# Server
PORT=4000
NODE_ENV=development

# JWT (use a long random string in production)
JWT_SECRET=change-me-to-a-strong-secret-min-32-chars
JWT_EXPIRES_IN=7d

# --- M-Pesa (Ethiopia sandbox matches Postman "mpesa-developers-api" collection)
# Never commit real keys. Rotate credentials in the developer portal if they were exposed.
# Base URL: same as Postman (sandbox)
MPESA_BASE_URL=https://apisandbox.safaricom.et

# Postman "Generate Token" request uses Basic auth:
#   Username  -> MPESA_CONSUMER_KEY
#   Password  -> MPESA_CONSUMER_SECRET
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=

# Postman B2C + STK body: BusinessShortCode / PartyA
MPESA_SHORTCODE=

# STK Lipa Na M-Pesa Online passkey (plain text from portal). Used in Password = Base64(shortcode + passkey + timestamp).
MPESA_PASSKEY=

# Postman B2C: InitiatorName + SecurityCredential (encrypted string from portal)
MPESA_INITIATOR_NAME=
MPESA_SECURITY_CREDENTIAL=

# Optional B2C text (Postman uses "Pay to Customer")
# MPESA_B2C_REMARKS=Pay to Customer
# Optional OriginatorConversationID prefix (Postman uses "Partner name -<uuid>")
# MPESA_B2C_ORIGINATOR_PREFIX=Partner name

# STK: sandbox test MSISDN (Postman PartyA / PhoneNumber). Overrides farmer phone for STK if set.
# MPESA_STK_MSISDN=2517XXXXXXXX

# Ethiopia STK only: ReferenceData (Postman sample uses CashierName). Override with JSON array if needed:
# MPESA_STK_REFERENCE_DATA=[{"Key":"CashierName","Value":"Cha cha"}]
# MPESA_STK_CASHIER_NAME=AgriCredit

# STK labels (Postman sample used AccountReference "Fast" — override to match your app)
# MPESA_STK_ACCOUNT_REF=AgriCredit
# MPESA_STK_TX_DESC=Loan repayment
# MPESA_STK_MERCHANT_PREFIX=Partner names

# Callbacks — use your public HTTPS URL or webhook.site (must match what you whitelist in the portal)
MPESA_CALLBACK_URL=https://example.com/mpesa-callback
# MPESA_RESULT_URL=
# MPESA_QUEUE_TIMEOUT_URL=
# MPESA_STK_CALLBACK_URL=

# Default: repayment/disburse require a real Safaricom STK/B2C acceptance (no fake success).
# Set to true only for offline demos when the sandbox is unreachable (records success anyway).
# MPESA_ALLOW_SIMULATED_FALLBACK=false

# STK: default true — HTTP success only means "prompt sent". Loan is updated when CallBackURL hits POST /mpesa/webhook/stk.
# Set to false for legacy hackathon behavior (record success immediately when STK returns ResponseCode 0).
# MPESA_RECORD_REPAYMENT_ON_CALLBACK_ONLY=true

# Local sandbox: after /mpesa/repay, confirm pending payment with body { "transactionRef": "<stkAccountRef from JSON>" }
# Optional header X-Dev-Stk-Secret if DEV_STK_CONFIRM_SECRET is set.
# DEV_STK_CONFIRM_SECRET=

# Kenya Daraja sandbox instead: MPESA_BASE_URL=https://sandbox.safaricom.co.ke (different paths + no Ethiopia ReferenceData branch)
