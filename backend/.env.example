# MongoDB (Atlas or local replica set for Prisma)
DATABASE_URL="mongodb://127.0.0.1:27017/agricredit?replicaSet=rs0&directConnection=true"

# Server
PORT=4000
NODE_ENV=development

JWT_SECRET=change-me-to-a-strong-secret-min-32-chars
JWT_EXPIRES_IN=7d

# --- M-Pesa (Ethiopia: apisandbox.safaricom.et — match Postman mpesa-developers-api) ---
# Never commit real keys. Copy to .env and fill in.

MPESA_MOCK_MODE=false

MPESA_BASE_URL=https://apisandbox.safaricom.et
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=

MPESA_SHORTCODE=
MPESA_PASSKEY=
# If you only have the Postman STK field called "Password" and it looks like base64,
# you probably copied base64(passkey). The backend will auto-decode base64(passkey) here.

MPESA_INITIATOR_NAME=
MPESA_SECURITY_CREDENTIAL=

MPESA_CALLBACK_URL=https://example.com/mpesa-callback
MPESA_RESULT_URL=https://example.com/mpesa-callback
MPESA_QUEUE_TIMEOUT_URL=https://example.com/mpesa-callback
MPESA_STK_CALLBACK_URL=https://example.com/mpesa-callback

MPESA_STK_ALLOW_PHONE_MISMATCH=true
MPESA_STK_USE_ENV_MSISDN=false
# MPESA_STK_MSISDN=2517XXXXXXXX

MPESA_RECORD_REPAYMENT_ON_CALLBACK_ONLY=true

# MPESA_ALLOW_SIMULATED_FALLBACK=false
# MPESA_STK_TX_DESC=Loan repayment
# MPESA_STK_MERCHANT_PREFIX=Partner names
# DEV_STK_CONFIRM_SECRET=
